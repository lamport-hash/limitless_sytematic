FROM python:3.12-slim

WORKDIR /app

COPY listener/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy shared py_core module
COPY py_core /app/py_core

COPY listener/app ./app/
COPY listener/config/downloader.yaml ./config/

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "app.screener_app:app", "--host", "0.0.0.0", "--port", "8000"]
